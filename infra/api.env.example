# Шаблон env-файла для matcheck-api контейнера.
#
# Реальный файл создаётся на VPS в /srv/matcheck/secrets/api.env
# с правами 600 и owner matcheck:matcheck. В репозитории он
# отсутствует намеренно — секреты вне VCS.
#
# Все <значения-в-угловых-скобках> заменить на реальные.

# =============== Runtime ===============
NODE_ENV=production
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# =============== CORS / Cookies ===============
CORS_ORIGIN=https://matcheck.fvds.ru
COOKIE_DOMAIN=matcheck.fvds.ru
COOKIE_SECURE=true

# Случайная строка ≥ 32 символа: openssl rand -base64 48
CSRF_SECRET=<32+ случайных байт base64>

# =============== JWT (Ed25519) ===============
# PEM-ключи в одну строку с буквальным escape \n. Получить:
#   awk 'NF {sub(/\r/, ""); printf "%s\\n", $0}' /srv/matcheck/secrets/jwt-private.pem
#   awk 'NF {sub(/\r/, ""); printf "%s\\n", $0}' /srv/matcheck/secrets/jwt-public.pem
JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n<вставить вывод awk>\n-----END PRIVATE KEY-----\n"
JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n<вставить вывод awk>\n-----END PUBLIC KEY-----\n"

JWT_ISSUER=matcheck-api
JWT_AUDIENCE=matcheck-web
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=14
REFRESH_TOKEN_ABSOLUTE_MAX_DAYS=90

# =============== Шифрование чувствительных полей БД (AES-256-GCM) ===============
# Map версия → base64 32-байтного ключа. При потере ключа Mail/EDO/LLM
# credentials восстановить НЕВОЗМОЖНО. Сгенерировать:
#   openssl rand -base64 32
APP_FIELD_ENCRYPTION_KEYS={"v1":"<base64 32 байта>"}
APP_FIELD_ENCRYPTION_ACTIVE_KEY_VERSION=v1

# =============== PostgreSQL (Yandex Managed) ===============
# Кавычки ОБЯЗАТЕЛЬНЫ — в URL есть &, без кавычек shell сломает.
# sslmode=verify-full + sslrootcert указывает на CA внутри контейнера
# (смонтированный из /srv/matcheck/secrets/yandex-ca/root.crt).
DATABASE_URL="postgres://<USER>:<PASSWORD>@<HOST>.mdb.yandexcloud.net:6432/<DBNAME>?sslmode=verify-full&sslrootcert=/etc/ssl/yandex/root.crt"

# CA для TLS-handshake к Yandex PG. postgres-js не парсит sslrootcert
# из URL, поэтому путь нужно дополнительно отдать Node через
# NODE_EXTRA_CA_CERTS. Без этого подключение падает с
# "self-signed certificate in certificate chain".
NODE_EXTRA_CA_CERTS=/etc/ssl/yandex/root.crt

# =============== БД ФОТ (read-only, внешняя) — список МОЛ ===============
# Отдельный read-only аккаунт (только SELECT) к Yandex Managed PG ФОТ.
# Тот же Yandex CA, что и основная БД — отдельный сертификат не нужен,
# NODE_EXTRA_CA_CERTS выше покрывает и это подключение.
# Если переменная не задана — раздел Справочники → МОЛ отдаёт пустой
# список с флагом «список мог устареть», приложение не падает.
FOT_DATABASE_URL="postgresql://mcp_readonly:<PASSWORD>@rc1d-m4ubd0uem0j9gqqc.mdb.yandexcloud.net:6432/FOT_Prod?sslmode=verify-full&sslrootcert=/etc/ssl/yandex/root.crt"

# =============== Redis (свой контейнер matcheck-redis) ===============
REDIS_URL=redis://matcheck-redis:6379/0

# =============== S3 (Cloud.ru Object Storage) ===============
S3_ENDPOINT=https://s3.cloud.ru
S3_REGION=ru-central-1
S3_BUCKET=<имя_бакета>
S3_ACCESS_KEY_ID=<...>
S3_SECRET_ACCESS_KEY=<...>
