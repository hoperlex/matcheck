# Размещение на VPS: /etc/logrotate.d/matcheck-nginx
# Только наши логи; чужие правила (/etc/logrotate.d/nginx и т.п.) не трогаем.

/var/log/nginx/matcheck.*.log {
    daily
    missingok
    rotate 14
    compress
    delaycompress
    notifempty
    create 0640 www-data adm
    sharedscripts
    postrotate
        [ -f /var/run/nginx.pid ] && kill -USR1 `cat /var/run/nginx.pid`
    endscript
}
